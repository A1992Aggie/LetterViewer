@inject OneDriveService OneDrive

<div class="breadcrumb-nav">
    @foreach (var (item, index) in Items.Select((item, i) => (item, i)))
    {
        if (index > 0)
        {
            <span class="breadcrumb-separator">/</span>
        }

        @if (index < Items.Count - 1)
        {
            <a href="javascript:void(0)" @onclick="() => OnNavigate.InvokeAsync(item.ItemId)">@item.Name</a>
        }
        else
        {
            <span class="breadcrumb-current">@item.Name</span>
        }
    }
</div>

@code {
    [Parameter] public List<BreadcrumbItem> Items { get; set; } = [];
    [Parameter] public EventCallback<string> OnNavigate { get; set; }
}
